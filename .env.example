# GreyEye — Environment Variables
# Copy to .env and fill in values for local development.

# PostgreSQL
DATABASE_URL=postgresql://greyeye:greyeye_dev@localhost:5432/greyeye

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=greyeye
S3_SECRET_KEY=greyeye_dev
S3_BUCKET_FRAMES=greyeye-frames
S3_BUCKET_EXPORTS=greyeye-exports
S3_BUCKET_MODELS=greyeye-models

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase (if using Option A)
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
