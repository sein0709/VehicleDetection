# GreyEye — Environment Variables
# Copy to .env and fill in values for local development.
# All service settings use the GREYEYE_ prefix (pydantic-settings).

# PostgreSQL (direct connection)
GREYEYE_DATABASE_URL=postgresql://greyeye:greyeye_dev@localhost:5432/greyeye

# Redis
GREYEYE_REDIS_URL=redis://localhost:6379/0

# NATS
GREYEYE_NATS_URL=nats://localhost:4222

# MinIO (S3-compatible)
GREYEYE_S3_ENDPOINT=http://localhost:9000
GREYEYE_S3_ACCESS_KEY=greyeye
GREYEYE_S3_SECRET_KEY=greyeye_dev
GREYEYE_S3_BUCKET_FRAMES=greyeye-frames
GREYEYE_S3_BUCKET_EXPORTS=greyeye-exports
GREYEYE_S3_BUCKET_MODELS=greyeye-models

# Auth / JWT
GREYEYE_JWT_SECRET=change-me-in-production
GREYEYE_JWT_ALGORITHM=HS256
GREYEYE_ACCESS_TOKEN_EXPIRE_MINUTES=15
GREYEYE_REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase
GREYEYE_SUPABASE_URL=https://your-project.supabase.co
GREYEYE_SUPABASE_ANON_KEY=
GREYEYE_SUPABASE_SERVICE_ROLE_KEY=

# Observability (optional for local dev)
GREYEYE_LOG_LEVEL=INFO
GREYEYE_JSON_LOGS=false
GREYEYE_TRACING_ENABLED=false
