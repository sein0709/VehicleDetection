        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(inference_detections_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
