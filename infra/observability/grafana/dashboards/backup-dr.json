{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Backup Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(time() - pgbackrest_backup_last_success_timestamp{type=\"full\"}) / 3600",
          "legendFormat": "Hours since last full",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "red", "value": 26 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Last Diff Backup",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(time() - pgbackrest_backup_last_success_timestamp{type=\"diff\"}) / 3600",
          "legendFormat": "Hours since last diff",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red", "value": 8 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "WAL Archive Lag",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(time() - pgbackrest_wal_archive_last_success_timestamp) / 60",
          "legendFormat": "Minutes since last WAL archive",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "DR Replica Lag",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "aws_rds_replica_lag_seconds{db_instance_identifier=~\".*-dr$\"}",
          "legendFormat": "DR lag (seconds)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 900 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Backup Size Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbackrest_backup_size_bytes{type=\"full\"}",
          "legendFormat": "Full backup",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbackrest_backup_size_bytes{type=\"diff\"}",
          "legendFormat": "Differential backup",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "id": 6,
      "title": "DR Replication Lag Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "aws_rds_replica_lag_seconds{db_instance_identifier=~\".*-dr$\"}",
          "legendFormat": "{{ db_instance_identifier }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(255,152,48,0.1)", "value": 300 },
              { "color": "rgba(242,73,92,0.1)", "value": 900 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "WAL Archive Gap Segments",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbackrest_wal_archive_gap_segments",
          "legendFormat": "WAL gap segments",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Restore Drill History",
      "type": "table",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "greyeye_restore_drill_last_result",
          "legendFormat": "Last result (1=pass, 0=fail)",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "greyeye_restore_drill_last_success_timestamp",
          "legendFormat": "Last success timestamp",
          "refId": "B",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "greyeye_restore_drill_duration_seconds",
          "legendFormat": "Last drill duration",
          "refId": "C",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "id": 9,
      "title": "S3 CRR Pending Operations",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "aws_s3_replication_pending_operations",
          "legendFormat": "{{ bucket }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Backup Job Success Rate (7d)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(kube_job_status_succeeded{job_name=~\".*pgbackrest.*\"}) / (sum(kube_job_status_succeeded{job_name=~\".*pgbackrest.*\"}) + sum(kube_job_status_failed{job_name=~\".*pgbackrest.*\"})) * 100",
          "legendFormat": "Success rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["greyeye", "backup", "dr", "pgbackrest"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "GreyEye — Backup & DR",
  "uid": "greyeye-backup-dr",
  "version": 1
}
