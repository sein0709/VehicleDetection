# ── GreyEye Auth Service ─────────────────────────────────────────────────────
# Multi-stage build: builder installs deps, runtime is minimal.
# Build context: repository root.

FROM python:3.11-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential && \
    rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /build

COPY pyproject.toml ./
COPY libs/shared_contracts/ libs/shared_contracts/
COPY services/auth_service/ services/auth_service/

RUN uv pip install --system --no-cache \
    ./libs/shared_contracts \
    ./services/auth_service

# ── Runtime ──────────────────────────────────────────────────────────────────
FROM python:3.11-slim

RUN groupadd -r greyeye && useradd -r -g greyeye -d /app -s /sbin/nologin greyeye

COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

WORKDIR /app
COPY services/auth_service/auth_service/ auth_service/

USER greyeye

EXPOSE 8001

HEALTHCHECK --interval=10s --timeout=3s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8001/healthz')" || exit 1

CMD ["uvicorn", "auth_service.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "8001", "--workers", "2"]
