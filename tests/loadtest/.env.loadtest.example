# GreyEye Load Test Configuration
# Copy to .env.loadtest and adjust for your environment.

# Target service URLs
GREYEYE_LT_INGEST_URL=http://localhost:8001
GREYEYE_LT_REPORTING_URL=http://localhost:8003
GREYEYE_LT_GATEWAY_URL=http://localhost:8080
GREYEYE_LT_NATS_URL=nats://localhost:4222
GREYEYE_LT_REDIS_URL=redis://localhost:6379/0

# Auth
GREYEYE_LT_JWT_SECRET=dev-secret-change-in-production

# MVP scenario
GREYEYE_LT_MVP_CAMERAS=10
GREYEYE_LT_MVP_FPS_PER_CAMERA=10
GREYEYE_LT_MVP_DURATION_SECONDS=120

# Scale scenario
GREYEYE_LT_SCALE_CAMERAS=100
GREYEYE_LT_SCALE_FPS_PER_CAMERA=10
GREYEYE_LT_SCALE_DURATION_SECONDS=300

# Backpressure test
GREYEYE_LT_BACKPRESSURE_FLOOD_RPS=200
GREYEYE_LT_BACKPRESSURE_DURATION_SECONDS=60

# Output
GREYEYE_LT_OUTPUT_DIR=tests/loadtest/results
